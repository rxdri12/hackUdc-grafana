          "query": "from(bucket: \"mixed_bucket\")\n  |> range(start: now(), stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"estado_aire_meteo\")\n  |> filter(fn: (r) => r[\"_field\"] == \"latitud\" or r[\"_field\"] == \"longitud\" or r[\"_field\"] == \"ica\" or r[\"_field\"] == \"rating\")\n  // 1. Agrupamos ESTRICTAMENTE por estación y campo. Ignoramos cualquier otra etiqueta que rompa la serie.\n  |> group(columns: [\"estacion\", \"_field\"])\n  // 2. Cogemos el PRIMER valor (el más cercano a now) en lugar del último\n  |> first() \n  // 3. Desagrupamos todo meterlo en un único saco antes de pivotar\n  |> group()\n  // 4. Pivotamos usando SOLO la estación como identificador de fila\n  |> pivot(rowKey: [\"estacion\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  // 5. Limpiamos las columnas\n  |> keep(columns: [\"estacion\", \"latitud\", \"longitud\", \"ica\", \"rating\"])",

      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUXDB}"
          },
          "query": "from(bucket: \"mixed_bucket\")\n  |> range(start: -2h)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"camaras_directo\")\n  |> filter(fn: (r) => r[\"_field\"] == \"latitud\" or r[\"_field\"] == \"longitud\" or r[\"_field\"] == \"url_foto\")\n  |> last()\n  |> pivot(rowKey:[\"nombre_camara\", \"concello\"], columnKey: [\"_field\"], valueColumn: \"_value\")\n  |> group() // <--- ¡ESTE ES EL TRUCO MÁGICO! Une todo en una sola tabla para Grafana",
          "refId": "A"
        }
      ],

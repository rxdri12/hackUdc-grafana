      "pluginVersion": "12.4.0",
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUXDB}"
          },
          "query": "from(bucket: \"meteo_bucket\")\n  |> range(start: now(), stop: 24h)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"prediccion_meteo\")\n  |> filter(fn: (r) => r[\"_field\"] == \"temperature\")\n  |> group(columns: [\"ciudad\"])\n  |> max()\n  |> keep(columns: [\"ciudad\", \"_value\"])\n  |> sort(columns: [\"_value\"], desc: true) // <-- Ordena de más calor a más frío\n  |> rename(columns: {_value: \"Temperatura (°C)\"}) // <-- Le cambia el nombre feo",
          "refId": "A"
        }
      ],
      "title": "New panel",
      "transformations": [
        {
          "id": "organize",
          "options": {}
        }
      ],
      "transparent": true,
      "type": "bargauge"
    }
